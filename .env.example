# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Telegram MTProto (scripts/import-group-history — только для импорта истории)
# Получить: https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Geocoding
NOMINATIM_USER_AGENT=gents-travel-bot
GOOGLE_MAPS_API_KEY=          # optional

# Admin
ADMIN_TOKEN=

# App URL (for webhook registration)
APP_URL=

# Travel Story: PATCH /api/trip/:id/travel-story, bootstrap, курация медиа/локаций
# Production: обязателен + заголовок Authorization: Bearer <токен>
# Development: без токена в env мутации часто разрешены (см. story-edit-auth)
STORY_EDIT_TOKEN=
# NEXT_PUBLIC_STORY_EDIT_TOKEN не обязателен: next.config.js подставляет его из STORY_EDIT_TOKEN
# (если нужно разное значение только на клиенте — задайте NEXT_PUBLIC_STORY_EDIT_TOKEN вручную)
# NEXT_PUBLIC_STORY_EDIT_TOKEN=

# Next.js dev: по умолчанию Webpack cache выключен (стабильнее, без битых чанков).
# Если нужна более быстрая пересборка и ты готов рисковать — NEXT_WEBPACK_CACHE=1
# NEXT_WEBPACK_CACHE=
